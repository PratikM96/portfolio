# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/)
# Long-cache true static media (filenames rarely change), but revalidate code and
# HTML every load so deploys take effect immediately. site.css / site.js are NOT
# content-hashed, so they must never be cached immutable or fixes won't reach users.
/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable
/assets/*.mp4
  Cache-Control: public, max-age=31536000, immutable
/assets/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/assets/*.pdf
  Cache-Control: public, max-age=86400, must-revalidate

/assets/*.css
  Cache-Control: public, max-age=0, must-revalidate
/assets/*.js
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Favicons live at the site root. Cache a day, revalidate, so an icon change
# propagates without a year-long immutable lock.
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
/*.png
  Cache-Control: public, max-age=86400, must-revalidate

# Basic security headers
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy-Report-Only: default-src 'self'; img-src 'self' https://cdn.mehtapratik.com https://*.google-analytics.com data:; media-src 'self' https://cdn.mehtapratik.com; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://*.google-analytics.com https://static.cloudflareinsights.com; connect-src 'self' https://*.google-analytics.com https://*.googletagmanager.com https://cdn.mehtapratik.com https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
