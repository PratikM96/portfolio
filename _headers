# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/)
# Long-cache true static media (filenames rarely change), but revalidate code and
# HTML every load so deploys take effect immediately. site.css / site.js are NOT
# content-hashed, so they must never be cached immutable or fixes won't reach users.
/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable
/assets/*.mp4
  Cache-Control: public, max-age=31536000, immutable
/assets/*.pdf
  Cache-Control: public, max-age=86400, must-revalidate

/assets/*.css
  Cache-Control: public, max-age=0, must-revalidate
/assets/*.js
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Basic security headers
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
